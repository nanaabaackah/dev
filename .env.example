# Copy this file to .env.development for local work and replace placeholders.
APP_ENV="development"
DATABASE_URL_DEVELOPMENT="postgresql://username:password@localhost:5432/dev"
# DATABASE_URL_PRODUCTION="postgresql://username:password@host:5432/production"
DATABASE_SSL_MODE="disable"
# DATABASE_SSL_REJECT_UNAUTHORIZED="true"
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
ENFORCE_DATABASE_ISOLATION="true"
VITE_API_PROXY_TARGET="http://localhost:8080"
RATE_LIMIT_MAX="1000"
RATE_LIMIT_WINDOW_MS="900000"
APP_BASE_URL="http://localhost:5173"
OAUTH_TOKEN_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
DEFAULT_ADMIN_EMAIL="dev@nanaabaackah.com"
BY_NANA_ORG_NAME="By Nana"
BY_NANA_ORG_SLUG="bynana"
REEBS_DATABASE_SSL_REJECT_UNAUTHORIZED="false"
FAAKO_DATABASE_SSL_REJECT_UNAUTHORIZED="false"
ACCOUNT_INVITE_FROM_EMAIL="alerts@nanaabaackah.com"
ALERT_EMAIL_ENABLED="true"
ALERT_EMAIL_RECIPIENTS="dev@nanaabaackah.com"
SMS_NOTIFICATIONS_AVAILABLE="false"
ALERT_SMS_ENABLED="false"
ALERT_SMS_RECIPIENTS="+15550102000"
ALERT_NOTIFY_OFFLINE="true"
ALERT_NOTIFY_DEGRADED="true"
ALERT_COOLDOWN_MS="900000"
SMS_ALLOW_NON_PRODUCTION="false"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15550102000"
EMAIL_SENDER_NAME="Your Organization Name"
ACCOUNT_SETUP_TOKEN_TTL_HOURS="72"
RENT_QUARTERLY_EMAIL_ENABLED="true"
RENT_QUARTERLY_EMAIL_HOUR_UTC="09"
RENT_QUARTERLY_EMAIL_MINUTE_UTC="00"
RENT_QUARTERLY_FROM_EMAIL="alerts@nanaabaackah.com"
RENT_REPLY_TO_EMAIL=""
