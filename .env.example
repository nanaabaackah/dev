# Copy this file to .env.development for local work and replace placeholders.
APP_ENV="development"
DATABASE_URL_DEVELOPMENT="postgresql://username:password@localhost:5432/dev"
# DATABASE_URL_PRODUCTION="postgresql://username:password@host:5432/production"
ENFORCE_DATABASE_ISOLATION="true"
VITE_API_PROXY_TARGET="http://localhost:8080"
RATE_LIMIT_MAX="1000"
RATE_LIMIT_WINDOW_MS="900000"
