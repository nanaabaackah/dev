# Copy this file to .env.development for local work and replace placeholders.
APP_ENV="development"
DATABASE_URL_DEVELOPMENT="postgresql://username:password@localhost:5432/dev"
# DATABASE_URL_PRODUCTION="postgresql://username:password@host:5432/production"
ENFORCE_DATABASE_ISOLATION="true"
VITE_API_PROXY_TARGET="http://localhost:8080"
RATE_LIMIT_MAX="1000"
RATE_LIMIT_WINDOW_MS="900000"
APP_BASE_URL="http://localhost:5173"
DEFAULT_ADMIN_EMAIL="dev@nanaabaackah.com"
ACCOUNT_INVITE_FROM_EMAIL="alerts@nanaabaackah.com"
ACCOUNT_SETUP_TOKEN_TTL_HOURS="72"
RENT_QUARTERLY_EMAIL_ENABLED="true"
RENT_QUARTERLY_EMAIL_HOUR_UTC="09"
RENT_QUARTERLY_EMAIL_MINUTE_UTC="00"
RENT_QUARTERLY_FROM_EMAIL="alerts@nanaabaackah.com"
INVOICE_FROM_EMAIL="alerts@nanaabaackah.com"
