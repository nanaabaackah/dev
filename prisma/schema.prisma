generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  roles Role[]
  users User[]
  bookings Booking[]
  bookingSettings BookingSettings?
  calendarIntegrations CalendarIntegration[]
}

model Role {
  id             Int           @id @default(autoincrement())
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  permissions    Json?

  users User[]

  @@unique([organizationId, name])
}

model User {
  id             Int           @id @default(autoincrement())
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id])
  roleId         Int
  role           Role          @relation(fields: [roleId], references: [id])
  firstName      String
  lastName       String
  fullName       String
  email          String        @unique
  password       String
  status         UserStatus    @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Booking {
  id            Int            @id @default(autoincrement())
  organizationId Int
  organization  Organization   @relation(fields: [organizationId], references: [id])
  externalId    String?
  source        BookingSource  @default(MANUAL)
  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime
  location      String?
  meetingLink   String?
  calendarEventId String?
  calendarProvider CalendarProvider?
  status        BookingStatus  @default(CONFIRMED)
  attendeeEmail String?
  attendeeName  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([organizationId, externalId, source])
  @@index([organizationId, calendarProvider, calendarEventId])
  @@index([organizationId, startAt])
}

model BookingSettings {
  id             Int           @id @default(autoincrement())
  organizationId Int           @unique
  organization   Organization  @relation(fields: [organizationId], references: [id])
  bookingLink    String?
  calendarEmail  String?
  defaultLocation String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model CalendarIntegration {
  id               Int              @id @default(autoincrement())
  organizationId   Int
  organization     Organization     @relation(fields: [organizationId], references: [id])
  provider         CalendarProvider
  accessToken      String
  refreshToken     String?
  tokenExpiry      DateTime?
  scope            String?
  email            String?
  calendarId       String?
  lastSyncedAt     DateTime?
  channelId        String?
  channelToken     String?
  channelResourceId String?
  channelExpiration DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([organizationId, provider])
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum BookingSource {
  MANUAL
  GOOGLE_CALENDAR
}

enum BookingStatus {
  CONFIRMED
  TENTATIVE
  CANCELED
}

enum CalendarProvider {
  GOOGLE_CALENDAR
}
