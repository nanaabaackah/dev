{
  "name": "dev-nanaabaackah-com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test",
    "preview": "vite preview",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate:dev": "APP_ENV=development prisma migrate dev",
    "db:status:dev": "APP_ENV=development prisma migrate status",
    "db:status:prod": "APP_ENV=production prisma migrate status",
    "db:deploy:dev": "APP_ENV=development prisma migrate deploy",
    "db:deploy:prod": "APP_ENV=production prisma migrate deploy",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "server:dev": "APP_ENV=development node backend/server.js",
    "server:prod": "APP_ENV=production node backend/server.js",
    "server:dev:with-migrate": "npm run db:deploy:dev && npm run server:dev",
    "server:prod:with-migrate": "npm run db:deploy:prod && npm run server:prod",
    "server:with-migrate": "npm run migrate:deploy && node backend/server.js",
    "server": "node backend/server.js",
    "postinstall": "node -e \"const hasDbUrl = Boolean(process.env.DATABASE_URL || process.env.DATABASE_URL_DEVELOPMENT || process.env.DATABASE_URL_PRODUCTION); if (!process.env.NETLIFY && hasDbUrl) { require('child_process').execSync('prisma generate', { stdio: 'inherit' }); } else { console.log('Skipping prisma generate'); }\""
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.2.0",
    "animejs": "^4.3.6",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "iconsax": "^0.0.1",
    "iconsax-react": "^0.0.8",
    "jquery": "^3.7.1",
    "jquery.easing": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "pg": "^8.11.2",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.2",
    "resend": "^4.0.0",
    "stellar.js": "^0.6.5",
    "waypoints": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prisma": "^7.2.0",
    "vite": "^6.3.5"
  }
}
